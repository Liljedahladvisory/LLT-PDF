{
  "identifier": "default",
  "description": "Default capabilities for LLT PDF",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read",
    "fs:allow-read-file",
    "fs:allow-write",
    "fs:allow-write-file",
    "core:webview:allow-webview-position",
    "core:webview:allow-set-webview-position",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://script.google.com/*" },
        { "url": "https://script.googleusercontent.com/*" },
        { "url": "https://raw.githubusercontent.com/*" },
        { "url": "https://api.github.com/*" }
      ]
    }
  ]
}
